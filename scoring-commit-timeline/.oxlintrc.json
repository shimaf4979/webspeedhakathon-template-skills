{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "rules": {
    "eslint/max-lines": [
      "error",
      {
        "max": 200,
        "skipBlankLines": false,
        "skipComments": false
      }
    ]
  },
  "ignorePatterns": [
    "**/node_modules/**",
    "**/.svelte-kit/**",
    "**/build/**",
    "**/dist/**",
    "**/*.svelte"
  ]
}
